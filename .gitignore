# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo

# Foundry
contracts/cache/
contracts/out/
# Deploy broadcast JSONs ARE tracked despite this ignore: they were
# force-added (git add -f) on purpose as a public record of the deploys.
# The ignore only stops NEW broadcast output (local anvil runs etc.)
# from being staged by accident.
contracts/broadcast/
contracts/.env

# Node / frontend
node_modules/
dist/
.env
.env.local

# Python (simulation)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs / reports
*.log
coverage/
lcov.info

# Marketing renderer artifacts (regenerable from token icons + the renderer
# script). The plan itself is tracked at docs/marketing-plan.md; this dir holds
# only render output (mp4/png/html + cache), so the whole thing is regenerable.
marketing-plan/

# Claude Code worktree checkouts (internal tooling state, not project content).
# .claude/launch.json stays tracked; only the throwaway worktrees are ignored.
.claude/worktrees/

# Design-skill handoff deliverables (jsx/html/png mockups). Kept locally as
# reference but not tracked; the canonical design decisions live in the PRD/docs.
docs/design_handoff_*/

# Token icon source folders (operator-supplied marketing assets, may include
# images whose redistribution rights aren't ours to grant)
/token icons/
/liberty-token-logos/
