# Tagwall frontend env vars.
#
# Copy to `.env` and fill in. `.env` is gitignored. Vite reads VITE_-prefixed
# vars at build/dev time; non-prefixed vars are ignored at the bundle
# boundary (a Vite security feature, not a bug).
#
# Mirror operators: every VITE_FILTER_*_ENABLED flag defaults ON for the
# Tagwall reference frontend. To run a maximally permissive mirror, set the
# flags you don't want to false. To run a stricter mirror, swap the URLs /
# keys for your own.

# ---------------------------------------------------------------------------
# Pre-launch holding page
# ---------------------------------------------------------------------------

# When `true`, every route resolves to the holding page (no canvas, no
# embed). Flip to anything else (or unset) to ship the full app. Build-
# time flag — flipping it requires a rebuild + redeploy.
VITE_HOLDING_PAGE_MODE=false

# ---------------------------------------------------------------------------
# Social links
# ---------------------------------------------------------------------------
# Used by both the holding page CTA and the main-app footer. Empty values
# render the social button visually disabled (holding page) or hide the
# footer link (main app), so a missing handle never produces a broken
# `href="#"`.
VITE_TAGWALL_TWITTER_URL=
VITE_TAGWALL_TELEGRAM_URL=

# ---------------------------------------------------------------------------
# Filter posture (cpa-brief.md §2)
# ---------------------------------------------------------------------------

# OFAC sanctions filter via the Chainalysis on-chain oracles. Free; no
# API key. PulseChain (mainnet + testnet) and Anvil have no Chainalysis
# oracle, so the filter degrades to a no-op there. Default ON.
#
# Set to "false" to disable on all chains (mirror operators with their own
# compliance posture).
VITE_FILTER_OFAC_ENABLED=true

# Outbound URL safety check via Cloudflare Security DNS (1.1.1.2 / DoH).
# Free, public, no API key — chosen over Google Safe Browsing because the
# latter requires every mirror operator to register their own API key,
# which breaks the "download the bundle and run" property. Default ON.
# Set to "false" to skip the hostname check (mirrors that prefer to ship
# their own URL safety pipeline).
VITE_FILTER_URL_SAFETY_ENABLED=true

# Static block-list URL (cpa-brief.md §2.1, Phase C). Signed JSON
# published by the operator listing pixel rectangles, addresses, or
# link hashes to mask at render time. Frontend fetches at boot,
# verifies the ed25519 signature against VITE_FILTER_PUBKEY, then
# applies the entries. Empty URL or missing pubkey disables the filter.
#
# Mirror operators with their own posture: point both at your own list
# + pubkey. To run a maximally permissive mirror, leave both unset.
#
# Generate a fresh keypair: `node scripts/sign-filter-list.mjs --gen-key`
# Sign the list:
#   node scripts/sign-filter-list.mjs \
#     --in  filter-list.unsigned.json \
#     --out web/public/filter-list.json \
#     --key /path/to/key.hex
VITE_FILTER_STATIC_LIST_URL=
VITE_FILTER_PUBKEY=
